  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows for the electronic filing of domestic violence/sexual assault reporting forms by law enforcement agencies, enhances the information to be included on the reporting forms, and clarifies that the reporting forms should be submitted monthly."
